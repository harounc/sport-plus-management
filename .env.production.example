DJANGO_SETTINGS_MODULE=spm.settings_prod
DJANGO_SECRET_KEY=generate-a-long-random-secret
DJANGO_ALLOWED_HOSTS=harounc.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://harounc.com
DB_ENGINE=postgresql
DB_NAME=spm
DB_USER=spm
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432
DEFAULT_FROM_EMAIL=site@harounc.com
CONTACT_EMAIL=contact@harounc.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
